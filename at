# UDM field mappings
    exact_fields = [
        ("principal.ip", na_if_empty(Principal_IP)),
        ("principal.user.userid", na_if_empty(principal_user_userid)),
        ('security_result.detection_fields["IOARuleName"]', na_if_empty(detection_title)),
    ]

    regex_fields = [
        ("target.process.command_line", to_exact_regex(target_process_command_line)),
        ("principal.process.parent_process.parent_process.file.names", to_exact_regex(ParentProcessFileName)),
        ("principal.process.parent_process.file.full_path", to_exact_regex(ParentImageFileName)),
        ("principal.process.parent_process.parent_process.command_line", to_exact_regex(GrandparentCommandLine)),
        ("principal.process.parent_process.parent_process.file.full_path", to_exact_regex(GrandparentImageFileName)),
        ("principal.process.file.full_path", to_exact_regex(FilePath_FileName)),
        ("principal.process.parent_process.command_line", to_exact_regex(ParentCommandLine)),
    ]

    query_parts = []
    for udm, val in exact_fields:
        if val != "NA":
            query_parts.append(f'{udm} = "{val}"')
    for udm, val in regex_fields:
        if val != "NA":
            query_parts.append(f'{udm} = /{val}/')

    query = " AND ".join(query_parts) if query_parts else "NA"

    result = [{
        "Display_Name": na_if_empty(Display_Name),
        "Added_by": na_if_empty(Added_by),
        "Custom_Rules": Custom_Rules,
        "query": query
    }]

    status = EXECUTION_STATE_COMPLETED
    output_message = "Successful"
    result_value = None
    siemplify.result.add_result_json(result)
