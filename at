from __future__ import annotations

import json
from typing import Any

import requests

from TIPCommon.base.action import Action
from TIPCommon.extraction import extract_action_param, extract_configuration_param
from TIPCommon import validation
from TIPCommon.utils import is_empty_string_or_none
from TIPCommon.types import SingleJson

import customconsts as consts
from customexceptions import (
    GoogleChronicleManagerError,
    GoogleChronicleValidationError,
)
from CustomGoogleChronicleManager import (
    GoogleChronicleManager,
)
from CustomGoogleChronicleManagerV2 import GoogleChronicleManagerV2
from customutils import validate_api_root_for_backstory


# Path appended to the configured Chronicle API root. The configured
# api_root is expected to already include the
# v1alpha/projects/{P}/locations/{L}/instances/{I} segment.
RULE_EXCLUSIONS_PATH = "findingsRefinements"


class UpdateRuleExclusionAction(Action):

    def __init__(self) -> None:
        super().__init__(consts.UPDATE_RULE_EXCLUSION_SCRIPT_NAME)
        self.output_message: str = ""
        self.json_results: SingleJson = {}

    def _extract_action_parameters(self) -> None:
        self.params.user_service_account = extract_configuration_param(
            self.soar_action,
            provider_name=consts.INTEGRATION_NAME,
            param_name="User's Service Account",
            remove_whitespaces=False,
        )

        self.params.workload_identity_email = extract_configuration_param(
            self.soar_action,
            provider_name=consts.INTEGRATION_NAME,
            param_name="Workload Identity Email",
        )

        self.params.api_root = extract_configuration_param(
            self.soar_action,
            provider_name=consts.INTEGRATION_NAME,
            param_name="API Root",
            is_mandatory=True,
            print_value=True,
        )

        self.params.verify_ssl = extract_configuration_param(
            self.soar_action,
            provider_name=consts.INTEGRATION_NAME,
            param_name="Verify SSL",
            is_mandatory=True,
            input_type=bool,
            print_value=True,
        )

        self.params.refinement_id = extract_action_param(
            self.soar_action,
            param_name="Refinement ID",
            is_mandatory=True,
            print_value=True,
        )

        self.params.display_name = extract_action_param(
            self.soar_action,
            param_name="Display Name",
            print_value=True,
        )

        self.params.query = extract_action_param(
            self.soar_action,
            param_name="Query",
            print_value=True,
        )

        self.params.enabled = extract_action_param(
            self.soar_action,
            param_name="Enabled",
            input_type=bool,
            print_value=True,
        )

    def _validate_params(self) -> None:
        validator = validation.ParameterValidator(self.soar_action)
        if not is_empty_string_or_none(self.params.user_service_account):
            self.params.user_service_account = validator.validate_json(
                param_name="User's Service Account",
                json_string=self.params.user_service_account,
                print_value=False,
            )
        validate_api_root_for_backstory(self.params.api_root)

        if is_empty_string_or_none(self.params.refinement_id):
            raise GoogleChronicleValidationError(
                "Parameter \"Refinement ID\" cannot be empty."
            )

        # Require at least one field to actually update.
        if (
            is_empty_string_or_none(self.params.display_name)
            and is_empty_string_or_none(self.params.query)
            and self.params.enabled is None
        ):
            raise GoogleChronicleValidationError(
                "At least one of \"Display Name\", \"Query\", or "
                "\"Enabled\" must be provided to update the "
                "rule exclusion."
            )

    def _init_api_clients(self) -> GoogleChronicleManager:
        # Manager is reused only to obtain an authenticated requests
        # session against the Chronicle API. All endpoint logic stays
        # in this action.
        return GoogleChronicleManagerV2.create_manager_instance(
            user_service_account=self.params.user_service_account,
            chronicle_soar=self.soar_action,
            api_root=self.params.api_root,
            verify_ssl=self.params.verify_ssl,
            workload_identity_email=self.params.workload_identity_email,
        )

    def _build_request_url(self) -> str:
        api_root = (
            self.params.api_root
            if self.params.api_root.endswith("/")
            else f"{self.params.api_root}/"
        )
        # Accepts either a bare ID (fr_<uuid>) or a full resource path
        # ending in the ID — we always strip down to the last segment.
        refinement_id = (
            self.params.refinement_id.rstrip("/").split("/")[-1]
        )
        return f"{api_root}{RULE_EXCLUSIONS_PATH}/{refinement_id}"

    def _build_update_mask_and_body(self) -> tuple[str, dict[str, Any]]:
        """Build the update_mask query string and the request body
        from whichever optional fields the user actually provided."""
        update_fields: list[str] = []
        body: dict[str, Any] = {}

        if not is_empty_string_or_none(self.params.display_name):
            update_fields.append("display_name")
            body["displayName"] = self.params.display_name

        if not is_empty_string_or_none(self.params.query):
            update_fields.append("query")
            body["query"] = self.params.query

        if self.params.enabled is not None:
            update_fields.append("enabled")
            body["enabled"] = self.params.enabled

        return ",".join(update_fields), body

    def _perform_action(self, _=None) -> None:
        updated_refinement = self._update_refinement()
        self._process_api_response(updated_refinement)

    def _update_refinement(self) -> SingleJson:
        url = self._build_request_url()
        session = self.api_client.session
        update_mask, body = self._build_update_mask_and_body()

        self.soar_action.LOGGER.info(
            f"Updating rule exclusion "
            f"\"{self.params.refinement_id}\" at \"{url}\" "
            f"with update_mask=\"{update_mask}\"."
        )
        self.soar_action.LOGGER.info(
            f"Request body: {json.dumps(body)}"
        )

        try:
            response = session.patch(
                url,
                params={"update_mask": update_mask},
                json=body,
                verify=self.params.verify_ssl,
            )
            response.raise_for_status()
        except requests.exceptions.HTTPError as http_e:
            if response.status_code == 404:
                raise GoogleChronicleManagerError(
                    f"Rule exclusion with ID "
                    f"\"{self.params.refinement_id}\" was not found "
                    "in Google SecOps."
                ) from http_e
            if response.status_code == 409:
                raise GoogleChronicleManagerError(
                    "Update conflicts with an existing rule exclusion. "
                    "Choose a unique display name."
                ) from http_e
            raise GoogleChronicleManagerError(
                f"HTTP error while updating rule exclusion: {http_e}"
            ) from http_e
        except requests.exceptions.RequestException as req_e:
            raise GoogleChronicleManagerError(
                f"Network error while updating rule exclusion: {req_e}"
            ) from req_e

        try:
            response_json: SingleJson = response.json()
        except json.JSONDecodeError as json_e:
            raise GoogleChronicleManagerError(
                "Invalid JSON in rule exclusion update response: "
                f"{json_e}"
            ) from json_e

        self.soar_action.LOGGER.info(
            "Rule exclusion successfully updated. "
            f"API response: {json.dumps(response_json)}"
        )

        return response_json

    def _process_api_response(
        self,
        refinement: SingleJson,
    ) -> None:
        display_name = refinement.get("displayName", "unknown")
        refinement_name = refinement.get("name", "")
        refinement_id = (
            refinement_name.split("/")[-1]
            if refinement_name
            else "unknown"
        )

        self.output_message = (
            f"Successfully updated rule exclusion "
            f"\"{display_name}\" (ID: {refinement_id}) "
            "in Google SecOps."
        )
        self.json_results = refinement


def main() -> None:
    action = UpdateRuleExclusionAction()
    action.run()


if __name__ == "__main__":
    main()
