from __future__ import annotations

import json
from typing import Any

import requests

from TIPCommon.base.action import Action
from TIPCommon.extraction import extract_action_param, extract_configuration_param
from TIPCommon import validation
from TIPCommon.utils import is_empty_string_or_none
from TIPCommon.types import SingleJson

import consts
from exceptions import (
    GoogleChronicleManagerError,
    GoogleChronicleValidationError,
)
from GoogleChronicleManager import (
    GoogleChronicleManager,
)
from GoogleChronicleManagerV2 import GoogleChronicleManagerV2
from utils import validate_api_root_for_backstory


# Path appended to the configured Chronicle API root. The configured
# api_root is expected to already include the
# v1alpha/projects/{P}/locations/{L}/instances/{I} segment.
RULE_EXCLUSIONS_PATH = "findingsRefinements"


class ListRuleExclusionsAction(Action):

    def __init__(self) -> None:
        super().__init__(consts.LIST_RULE_EXCLUSIONS_SCRIPT_NAME)
        self.output_message: str = ""
        self.json_results: list[SingleJson] = []

    def _extract_action_parameters(self) -> None:
        self.params.user_service_account = extract_configuration_param(
            self.soar_action,
            provider_name=consts.INTEGRATION_NAME,
            param_name="User's Service Account",
            remove_whitespaces=False,
        )

        self.params.workload_identity_email = extract_configuration_param(
            self.soar_action,
            provider_name=consts.INTEGRATION_NAME,
            param_name="Workload Identity Email",
        )

        self.params.api_root = extract_configuration_param(
            self.soar_action,
            provider_name=consts.INTEGRATION_NAME,
            param_name="API Root",
            is_mandatory=True,
            print_value=True,
        )

        self.params.verify_ssl = extract_configuration_param(
            self.soar_action,
            provider_name=consts.INTEGRATION_NAME,
            param_name="Verify SSL",
            is_mandatory=True,
            input_type=bool,
            print_value=True,
        )

        self.params.limit = extract_action_param(
            self.soar_action,
            param_name="Limit",
            input_type=int,
            print_value=True,
        )

        self.params.filter_query = extract_action_param(
            self.soar_action,
            param_name="Filter",
            print_value=True,
        )

    def _validate_params(self) -> None:
        validator = validation.ParameterValidator(self.soar_action)
        if not is_empty_string_or_none(self.params.user_service_account):
            self.params.user_service_account = validator.validate_json(
                param_name="User's Service Account",
                json_string=self.params.user_service_account,
                print_value=False,
            )
        validate_api_root_for_backstory(self.params.api_root)

        if self.params.limit is not None and self.params.limit <= 0:
            raise GoogleChronicleValidationError(
                "Parameter \"Limit\" must be a positive integer."
            )

    def _init_api_clients(self) -> GoogleChronicleManager:
        # Manager is reused only to obtain an authenticated requests
        # session against the Chronicle API. All endpoint logic stays
        # in this action.
        return GoogleChronicleManagerV2.create_manager_instance(
            user_service_account=self.params.user_service_account,
            chronicle_soar=self.soar_action,
            api_root=self.params.api_root,
            verify_ssl=self.params.verify_ssl,
            workload_identity_email=self.params.workload_identity_email,
        )

    def _build_request_url(self) -> str:
        api_root = (
            self.params.api_root
            if self.params.api_root.endswith("/")
            else f"{self.params.api_root}/"
        )
        return f"{api_root}{RULE_EXCLUSIONS_PATH}"

    def _perform_action(self, _=None) -> None:
        refinements = self._fetch_all_refinements()
        self._process_api_response(refinements)

    def _fetch_all_refinements(self) -> list[SingleJson]:
        url = self._build_request_url()
        session = self.api_client.session
        limit = self.params.limit

        self.soar_action.LOGGER.info(
            f"Listing rule exclusions from \"{url}\"."
        )

        collected: list[SingleJson] = []
        next_page_token: str | None = None

        while True:
            query_params: dict[str, Any] = {}
            if self.params.filter_query:
                query_params["filter"] = self.params.filter_query
            if next_page_token:
                query_params["pageToken"] = next_page_token

            try:
                response = session.get(
                    url,
                    params=query_params,
                    verify=self.params.verify_ssl,
                )
                response.raise_for_status()
            except requests.exceptions.RequestException as req_e:
                raise GoogleChronicleManagerError(
                    "Network error while listing rule exclusions: "
                    f"{req_e}"
                ) from req_e

            try:
                response_json = response.json()
            except json.JSONDecodeError as json_e:
                raise GoogleChronicleManagerError(
                    "Invalid JSON in rule exclusions response: "
                    f"{json_e}"
                ) from json_e

            page_results: list[SingleJson] = response_json.get(
                "findingsRefinements", []
            )

            for refinement in page_results:
                if limit is not None and len(collected) >= limit:
                    break
                collected.append(refinement)

            if limit is not None and len(collected) >= limit:
                break

            next_page_token = response_json.get("nextPageToken")
            if not next_page_token:
                break

        self.soar_action.LOGGER.info(
            f"API returned {len(collected)} rule exclusion(s) total "
            "across all pages."
        )

        if collected:
            self.soar_action.LOGGER.info(
                "Sample of first rule exclusion from API: "
                f"{json.dumps(collected[0])}"
            )

        return collected

    def _process_api_response(
        self,
        refinements: list[SingleJson],
    ) -> None:
        retrieved_count = len(refinements)

        if retrieved_count > 0:
            self.output_message = (
                f"Successfully retrieved {retrieved_count} rule "
                "exclusion(s) from Google SecOps."
            )
            self.json_results = refinements
        else:
            self.output_message = (
                "No rule exclusions were found in Google SecOps "
                "matching the specified criteria. Check filter "
                "parameter and instance configuration."
            )
            self.json_results = []


def main() -> None:
    action = ListRuleExclusionsAction()
    action.run()


if __name__ == "__main__":
    main()
